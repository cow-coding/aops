# ---- Database ----
# Option A: Use built-in DB (docker compose --profile db up -d)
POSTGRES_USER=agentops
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=agentops

# Option B: Use external DB (set DATABASE_URL, skip --profile db)
# DATABASE_URL=postgresql+asyncpg://user:pass@your-db-host:5432/agentops

# ---- Backend ----
SECRET_KEY=change-me-in-production-use-a-long-random-string
SERVER_URL=http://localhost
CORS_ORIGINS=["http://localhost"]

# ---- Ports (optional) ----
DB_PORT=5432
BACKEND_PORT=8000
FRONTEND_PORT=80
